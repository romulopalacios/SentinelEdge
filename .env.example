# ─────────────────────────────────────────────────────────────────────────────
# .env.example — SentinelEdge · Plataforma de Seguridad Perimetral
# Copiar como .env y ajustar valores
# NUNCA commitear el archivo .env real
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=info

# ── PostgreSQL (TimescaleDB) ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=perimetral_db
POSTGRES_USER=perimetral_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://perimetral_user:change_me_strong_password@postgres:5432/perimetral_db

# ── RabbitMQ — Event Bus ──────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=perimetral_rmq
RABBITMQ_PASS=change_me_rmq_password
RABBITMQ_VHOST=perimetral
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://perimetral_rmq:change_me_rmq_password@rabbitmq:5672/perimetral

# ── MQTT Broker (Mosquitto) ───────────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USERNAME=sentinel_ingestion
MQTT_PASSWORD=change_me_mqtt_password
# Topic base: sentineledge/{tenant_id}/sensors/{sensor_id}/events
MQTT_TOPIC_BASE=sentineledge
MQTT_TOPIC_WILDCARD=sentineledge/+/sensors/+/events

# ── Redis — Cache / Sesiones / Rate Limiting ──────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
# Descomentar si Redis tiene password:
# REDIS_PASSWORD=change_me_redis_password

# ── Nginx — API Gateway ───────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── JWT (compartido entre todos los servicios) ────────────────────────────────
JWT_SECRET=change_me_super_secret_key_min_32_chars_!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# ── Auth Service ──────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=auth-service
# Bcrypt cost factor (10 = balance seguridad/velocidad)
BCRYPT_SALT_ROUNDS=10

# ── Ingestion Service ─────────────────────────────────────────────────────────
INGESTION_SERVICE_PORT=8001
INGESTION_SERVICE_HOST=ingestion-service

# ── Rule Engine Service ───────────────────────────────────────────────────────
RULE_ENGINE_SERVICE_PORT=8002
RULE_ENGINE_SERVICE_HOST=rule-engine-service
# Máximo de reglas cacheadas por tenant en Redis
RULE_CACHE_TTL_SECONDS=60

# ── Alert Service ─────────────────────────────────────────────────────────────
ALERT_SERVICE_PORT=3002
ALERT_SERVICE_HOST=alert-service

# ── Query API Service ─────────────────────────────────────────────────────────
QUERY_API_SERVICE_PORT=8003
QUERY_API_SERVICE_HOST=query-api-service
# Paginación por defecto
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_API_RPM=300

# ── Notificaciones del Alert Service ─────────────────────────────────────────
# Todos son opcionales. Si no están configurados, las acciones se loguean
# pero no fallan (el sistema sigue funcionando sin ellos).

# Email (requiere SMTP_HOST mínimo, más ALERT_EMAIL_RECIPIENT)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=alerts@example.com
# SMTP_PASS=change_me
# SMTP_FROM=alerts@sentineledge.local
# ALERT_EMAIL_RECIPIENT=ops-team@example.com

# Webhook genérico (HTTP POST con payload JSON)
# ALERT_WEBHOOK_URL=https://your-webhook.example.com/sentineledge

# Slack Incoming Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
