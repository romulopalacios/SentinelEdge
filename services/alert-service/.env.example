# ─────────────────────────────────────────────────────────────────────────────
# Alert Service — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────

RABBITMQ_URL=amqp://perimetral_rmq:CHANGE_ME_RMQ_PASSWORD@localhost:5672/perimetral
RABBITMQ_INPUT_QUEUE=alert-service-queue
RABBITMQ_NOTIFY_EXCHANGE=perimetral.alerts
RABBITMQ_PREFETCH=50

DATABASE_URL=postgresql://perimetral_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/perimetral_db

REDIS_URL=redis://localhost:6379/3

JWT_SECRET=change_me_super_secret_key
JWT_ALGORITHM=HS256

# Severidades que disparan notificación inmediata
CRITICAL_SEVERITIES=critical,high

SERVICE_NAME=alert-service
SERVICE_PORT=3002
WS_PATH=/ws
LOG_LEVEL=info
ENV=development
