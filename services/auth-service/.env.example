# ─────────────────────────────────────────────────────────────────────────────
# Auth Service — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://perimetral_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/perimetral_db
DATABASE_POOL_MAX=10

REDIS_URL=redis://localhost:6379/0

# JWT — debe ser igual en todos los servicios que validan tokens
JWT_SECRET=change_me_super_secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_ALGORITHM=HS256

# Refresh token (duración)
REFRESH_TOKEN_EXPIRES_IN=7d

# Seguridad
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

SERVICE_NAME=auth-service
SERVICE_PORT=3001
LOG_LEVEL=info
ENV=development
