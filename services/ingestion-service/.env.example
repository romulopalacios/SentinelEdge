# ─────────────────────────────────────────────────────────────────────────────
# Ingestion Service — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────

# ── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_SUBSCRIBE=sensors/+/events/#
MQTT_CLIENT_ID=ingestion-service-01
MQTT_KEEPALIVE=60
MQTT_QOS=1

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://perimetral_rmq:perimetral_rmq_pass@localhost:5672/perimetral
RABBITMQ_EXCHANGE=perimetral.ingestion
RABBITMQ_ROUTING_KEY_PREFIX=event

# ── Servicio ──────────────────────────────────────────────────────────────────
SERVICE_NAME=ingestion-service
SERVICE_PORT=8010
LOG_LEVEL=INFO
ENV=development

# ── Validación de payload ─────────────────────────────────────────────────────
MAX_PAYLOAD_SIZE_BYTES=65536
