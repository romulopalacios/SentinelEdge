# ─────────────────────────────────────────────────────────────────────────────
# Query API Service — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://perimetral_user:perimetral_pass@localhost:5432/perimetral_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/2

# JWT — debe ser el mismo secret que auth-service
JWT_SECRET=change_me_super_secret_key
JWT_ALGORITHM=HS256

# Paginación
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# Cache de queries (segundos)
QUERY_CACHE_TTL=30

SERVICE_NAME=query-api-service
SERVICE_PORT=8001
LOG_LEVEL=INFO
ENV=development
