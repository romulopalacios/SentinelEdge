# ─────────────────────────────────────────────────────────────────────────────
# Rule Engine Service — Variables de Entorno  
# ─────────────────────────────────────────────────────────────────────────────

RABBITMQ_URL=amqp://perimetral_rmq:perimetral_rmq_pass@localhost:5672/perimetral
RABBITMQ_INPUT_QUEUE=rule-engine-queue
RABBITMQ_OUTPUT_EXCHANGE=perimetral.processed
RABBITMQ_PREFETCH_COUNT=100

DATABASE_URL=postgresql+asyncpg://perimetral_user:perimetral_pass@localhost:5432/perimetral_db

REDIS_URL=redis://localhost:6379/0

# Cache de reglas (segundos)
RULES_CACHE_TTL=60

SERVICE_NAME=rule-engine-service
SERVICE_PORT=8011
LOG_LEVEL=INFO
ENV=development
